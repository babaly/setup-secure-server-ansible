      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (rate(traefik_service_request_duration_seconds_sum{service=~\"$service\"}[5m])) / sum by (service) (rate(traefik_service_request_duration_seconds_count{service=~\"$service\"}[5m]))",
          "legendFormat": "{{ service }}"
