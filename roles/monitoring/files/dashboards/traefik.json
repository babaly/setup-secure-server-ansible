    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 14,
      "title": "TLS",
      "type": "row"
    },
    {
      "id": 15,
      "title": "TLS Certificate Expiry",
      "description": "TLS certificate expiration dates",
      "type": "table",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 25 },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "traefik_tls_certs_not_after",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 604800 },
              { "color": "green", "value": 2592000 }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false,
            "filterable": true
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "cn" },
            "properties": [
              { "id": "displayName", "value": "Common Name" },
              { "id": "custom.width", "value": 300 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "sans" },
            "properties": [
              { "id": "displayName", "value": "Subject Alternative Names" },
              { "id": "custom.width", "value": 400 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Expires At" },
              { "id": "unit", "value": "dateTimeAsIso" },
              { "id": "custom.width", "value": 200 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "countRows": false,
          "fields": ""
        },
        "sortBy": [
