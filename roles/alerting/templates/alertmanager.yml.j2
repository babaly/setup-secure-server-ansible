---
# {{ ansible_managed }}

global:
{% if email_enabled %}
  smtp_smarthost: "{{ smtp_host }}:{{ smtp_port }}"
  smtp_from: "{{ alert_email_from }}"
  smtp_auth_username: "{{ smtp_user }}"
  smtp_auth_password: "{{ smtp_password }}"
  smtp_require_tls: false
{% endif %}
{% if slack_enabled %}
  slack_api_url: "{{ slack_webhook_url }}"
{% endif %}

templates:
  - /etc/alertmanager/templates/*.tmpl

route:
  group_by:
    - alertname
    - severity
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
{% if slack_enabled and email_enabled %}
  receiver: slack-email
{% elif slack_enabled %}
  receiver: slack-only
{% elif email_enabled %}
  receiver: email-only
{% endif %}
  routes:
    - match:
        severity: critical
{% if slack_enabled and email_enabled %}
      receiver: slack-email
{% elif slack_enabled %}
      receiver: slack-only
{% elif email_enabled %}
      receiver: email-only
{% endif %}
    - match:
        severity: warning
{% if slack_enabled %}
      receiver: slack-only
{% elif email_enabled %}
      receiver: email-only
{% endif %}

receivers:
{% if slack_enabled and email_enabled %}
  - name: slack-email
    slack_configs:
      - channel: "{{ slack_channel }}"
        send_resolved: true
        title: '{% raw %}{{ template "slack.title" . }}{% endraw %}'
        text: '{% raw %}{{ template "slack.text" . }}{% endraw %}'
    email_configs:
      - to: "{{ alert_email_to }}"
        from: "{{ alert_email_from }}"
        smarthost: "{{ smtp_host }}:{{ smtp_port }}"
        auth_username: "{{ smtp_user }}"
        auth_password: "{{ smtp_password }}"
        require_tls: false
        html: '{% raw %}{{ template "email.body" . }}{% endraw %}'
        headers:
          Subject: '{% raw %}{{ template "email.subject" . }}{% endraw %}'
{% endif %}

{% if slack_enabled %}
  - name: slack-only
    slack_configs:
      - channel: "{{ slack_channel }}"
        send_resolved: true
        title: '{% raw %}{{ template "slack.title" . }}{% endraw %}'
        text: '{% raw %}{{ template "slack.text" . }}{% endraw %}'
{% endif %}

{% if email_enabled %}
  - name: email-only
    email_configs:
      - to: "{{ alert_email_to }}"
        from: "{{ alert_email_from }}"
        smarthost: "{{ smtp_host }}:{{ smtp_port }}"
        auth_username: "{{ smtp_user }}"
        auth_password: "{{ smtp_password }}"
        require_tls: false
        html: '{% raw %}{{ template "email.body" . }}{% endraw %}'
        headers:
          Subject: '{% raw %}{{ template "email.subject" . }}{% endraw %}'
{% endif %}

inhibit_rules:
  - source_match:
      severity: critical
    target_match:
      severity: warning
    equal:
      - alertname
